# GoREST MCP Plugin Configuration Example
# Copy this file to .env and update with your values

# Application
PORT=8080
APP_NAME=GoREST MCP Example

# JWT Authentication (Required)
# Minimum 32 characters for production
JWT_SECRET=your-secret-key-change-in-production-min-32-characters-long

# MCP Plugin Settings
MCP_ENABLED=true
MCP_RATE_LIMIT=60
MCP_LOG_LEVEL=info

# Database Configuration
DB_DRIVER=sqlite
DB_DSN=gorest_mcp.db

# PostgreSQL (if using)
# DB_DRIVER=postgres
# DB_DSN=postgres://gorest:gorest@localhost:5432/gorest?sslmode=disable
# POSTGRES_PASSWORD=gorest

# MySQL (if using)
# DB_DRIVER=mysql
# DB_DSN=gorest:gorest@tcp(localhost:3306)/gorest?parseTime=true
# MYSQL_PASSWORD=gorest
# MYSQL_ROOT_PASSWORD=rootpassword

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS (if needed)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
